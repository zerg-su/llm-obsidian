{
  "mcpProxy": {
    "baseURL": "http://127.0.0.1:9090",
    "addr": "127.0.0.1:9090",
    "name": "llm-obsidian MCP Gateway",
    "version": "1.0.0",
    "type": "streamable-http",
    "options": {
      "panicIfInvalid": false,
      "logEnabled": true
    }
  },
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "transportType": "streamable-http",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
