# ~/.config/mcp-gateway/secrets.env — API keys for gateway children.
#
#   mkdir -p ~/.config/mcp-gateway
#   cp scripts/mcp-gateway/secrets.env.example ~/.config/mcp-gateway/secrets.env
#   chmod 600 ~/.config/mcp-gateway/secrets.env
#
# Every ${VAR} placeholder in config.json must have a line here — the gateway
# sources this file and mcp-proxy expands the placeholders from the environment.
# `mcp-gateway.sh doctor` derives the required key list from config.json
# automatically and tells you what is missing. Never commit this file.

# context7 (library documentation MCP) — free key from https://context7.com dashboard
CONTEXT7_API_KEY=

# Add one line per ${VAR} you reference in config.json, e.g.:
# GITHUB_PAT=
