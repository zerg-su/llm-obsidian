{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-obsidian.local/schemas/vault-write-v1.schema.json",
  "title": "Vault write request v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "request_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"},
    "actor": {"type": "string"},
    "session": {"type": "string"},
    "log_entry": {"type": "string"},
    "hot_bullet": {"type": "string"},
    "hot_narrative": {"type": "string"},
    "hot_threads": {"type": "object"},
    "plan_close": {"type": "object"},
    "manifest_update": {"type": "object"},
    "moves": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["from", "to", "expected_sha256"],
        "properties": {
          "from": {"type": "string", "pattern": "^wiki/"},
          "to": {"type": "string", "pattern": "^wiki/"},
          "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object", "additionalProperties": false,
            "required": ["op", "path", "content"],
            "properties": {
              "op": {"const": "create"},
              "path": {"type": "string", "pattern": "^wiki/"},
              "content": {"type": "string"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["op", "path", "content", "expected_sha256"],
            "properties": {
              "op": {"const": "update"},
              "path": {"type": "string", "pattern": "^wiki/"},
              "content": {"type": "string"},
              "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["op", "path", "expected_sha256"],
            "properties": {
              "op": {"const": "delete"},
              "path": {"type": "string", "pattern": "^wiki/"},
              "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        ]
      }
    }
  },
  "anyOf": [
    {"required": ["pages"]}, {"required": ["log_entry"]},
    {"required": ["hot_bullet"]}, {"required": ["hot_narrative"]},
    {"required": ["hot_threads"]}, {"required": ["plan_close"]},
    {"required": ["manifest_update"]}, {"required": ["moves"]}
  ]
}
