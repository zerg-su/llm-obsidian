{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-obsidian.local/schemas/wiki-summary-v1.schema.json",
  "title": "Wiki Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "type", "title", "session", "body"],
  "properties": {
    "schema_version": {"const": 1},
    "type": {"enum": ["session", "decision", "runbook", "incident", "service-update", "repo-touch"]},
    "title": {"type": "string", "minLength": 1, "maxLength": 500},
    "session": {"type": ["string", "null"], "maxLength": 200},
    "body": {"type": "string", "minLength": 1, "maxLength": 200000}
  }
}
