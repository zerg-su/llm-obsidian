{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-obsidian.local/schemas/research-artifact-v1.schema.json",
  "title": "Isolated research artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "topic", "fetched_at", "sources", "fetch_errors"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "topic": {"type": "string", "minLength": 1, "maxLength": 2000},
    "fetched_at": {"type": "string", "format": "date-time"},
    "sources": {
      "type": "array", "minItems": 1, "maxItems": 50,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["url", "title", "content_sha256", "source_class", "clean_markdown"],
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "title": {"type": "string", "minLength": 1},
          "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "source_class": {"enum": ["official", "internal", "third-party"]},
          "trust": {"const": "untrusted"},
          "clean_markdown": {"type": "string", "minLength": 1, "maxLength": 500000}
        }
      }
    },
    "fetch_errors": {"type": "array", "items": {"type": "string"}, "maxItems": 100}
  }
}
