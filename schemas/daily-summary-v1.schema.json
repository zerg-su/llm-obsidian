{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-obsidian.local/schemas/daily-summary-v1.schema.json",
  "title": "Daily summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "date", "evidence_bundle_id", "bullets"],
  "properties": {
    "schema_version": {"const": 1},
    "date": {"type": "string", "format": "date"},
    "evidence_bundle_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "bullets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subject", "outcome", "compact", "evidence_ids"],
        "properties": {
          "subject": {"type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[^\\r\\n]+$"},
          "outcome": {"type": "string", "minLength": 10, "maxLength": 320, "pattern": "^[^\\r\\n]+$"},
          "compact": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[^\\r\\n]+$"},
          "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "session_labels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["session_id", "label"],
        "properties": {
          "session_id": {"type": "string"},
          "label": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[^\\r\\n]+$"}
        }
      }
    }
  }
}
