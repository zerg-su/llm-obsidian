{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-obsidian.local/schemas/daily-evidence-v1.schema.json",
  "title": "Daily evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "date", "generated_at", "bundle_id", "items", "session_map"],
  "properties": {
    "schema_version": {"const": 1},
    "date": {"type": "string", "format": "date"},
    "generated_at": {"type": "string", "format": "date-time"},
    "bundle_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title", "text"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z]+:[0-9]{3}$"},
          "kind": {"enum": ["session", "log", "git", "hot", "current"]},
          "title": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[^\\r\\n]+$"},
          "text": {"type": "string", "minLength": 1, "maxLength": 2000},
          "source": {"type": "string", "minLength": 1, "maxLength": 240, "pattern": "^[^\\r\\n]+$"}
        }
      }
    },
    "session_map": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["session_id", "label"],
        "properties": {
          "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$"},
          "label": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[^\\r\\n]+$"},
          "runtime": {"enum": ["claude", "codex", "other"]}
        }
      }
    }
  }
}
