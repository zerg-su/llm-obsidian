{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -x .claude/hooks/skill-router.sh ] && .claude/hooks/skill-router.sh || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -x .claude/hooks/command-capture.sh ] && .claude/hooks/command-capture.sh || true"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -x .claude/hooks/plan-capture.sh ] && .claude/hooks/plan-capture.sh || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -f wiki/hot.md ] && cat wiki/hot.md || true"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -x .claude/hooks/session-nudge.sh ] && .claude/hooks/session-nudge.sh || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS:-}\" != \"1\" ] && [ -n \"${CODEX_THREAD_ID:-}${CODEX_CI:-}${CODEX_MANAGED_BY_NPM:-}\" ] && exit 0; [ -f wiki/hot.md ] && cat wiki/hot.md || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .vault-meta; [ -x .claude/hooks/stop.sh ] && LLM_OBSIDIAN_ALLOW_CLAUDE_HOOKS=1 .claude/hooks/stop.sh > .vault-meta/stop-hook-last.log 2>&1 || true"
          }
        ]
      }
    ]
  }
}
